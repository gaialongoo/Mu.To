{
  "name": "museo-bff",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:viewer":        "cd viewer && vite",
    "dev:editor":        "cd editor && vite",
    "dev:marketplace":   "cd marketplace && vite",
    "build:viewer":      "cd viewer && vite build",
    "build:editor":      "cd editor && vite build",
    "build:marketplace": "cd marketplace && vite build",
    "build": "npm run build:viewer && npm run build:editor && npm run build:marketplace",
    "start": "node server_bff.js",
    "preview:viewer":      "cd viewer && vite preview",
    "preview:editor":      "cd editor && vite preview --base /editor/",
    "preview:marketplace": "cd marketplace && vite preview --base /marketplace/"
  },
  "dependencies": {
    "dotenv":    "^16.0.0",
    "express":   "^4.18.0",
    "react":     "^18.3.1",
    "react-dom": "^18.3.1",
    "undici":    "^6.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "rollup":     "npm:@rollup/wasm-node@^4.59.0",
    "typescript": "^5.0.0",
    "vite":       "^5.0.0"
  }
}