# Server MongoDB
MONGO_URI=mongodb://localhost:27017

# API Key per openAPI per il db
API_KEY=test
API_PORT=3000
# Con quale IP il server API ascolta (bind)
API_HOST=0.0.0.0
# Con quale IP gli altri server raggiungono l'API (connect)
API_CONNECT_HOST=127.0.0.1

# SVG Server (porta 3001)
SVG_HOST=127.0.0.1
SVG_PORT=3001

# BFF (porta 8080)
BFF_PORT=8080
BFF_HOST=0.0.0.0

# AI provider per object-chat — Groq (OpenAI-compatible, default URL api.groq.com)
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
# Incolla qui la chiave da https://console.groq.com (non committare questo file se contiene la key)
AI_API_KEY=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
# opzionale: override URL; altrimenti usa https://api.groq.com/openai/v1
# AI_BASE_URL=
# opzionale: origine pubblica dell'API (es. https://api.tuodominio.it) per URL assoluti immagini nel contesto IA
# PUBLIC_API_BASE=
AI_AUTH_BEARER=
AI_ALLOW_NO_AUTH=false

# --- Ollama locale (decommentare e svuota AI_API_KEY per tornare a Ollama) ---
# AI_PROVIDER=ollama
# AI_BASE_URL=http://192.168.1.200:11434/v1
# AI_MODEL=llama3.1:8b
# AI_ALLOW_NO_AUTH=true

# retrocompatibilita (puoi lasciare vuoti)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
