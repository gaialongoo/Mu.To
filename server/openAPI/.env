# Server MongoDB
MONGO_URI=mongodb://localhost:27017

# API Key per openAPI per il db
API_KEY=test
API_PORT=3000
# Con quale IP il server API ascolta (bind)
API_HOST=0.0.0.0
# Con quale IP gli altri server raggiungono l'API (connect)
API_CONNECT_HOST=127.0.0.1

# SVG Server (porta 3001)
SVG_HOST=127.0.0.1
SVG_PORT=3001

# BFF (porta 8080)
BFF_PORT=8080
BFF_HOST=0.0.0.0

# AI provider per object-chat 
AI_PROVIDER=ollama
AI_BASE_URL=http://192.168.1.200:11434/v1
AI_MODEL=llama3.1:8b
AI_API_KEY=
# opzionale: se il provider richiede token custom al posto della key
AI_AUTH_BEARER=
AI_ALLOW_NO_AUTH=true

# retrocompatibilita (puoi lasciare vuoti)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
